      "code": "AWS-SSM-SECRETS-001",
      "name": "SSM Parameter Store Harvesting",
      "description": "Iterate through Parameter Store to find and decrypt secrets (DB keys, API tokens).",
      "execution_mode": "per_binding",
      "execution_binding": "ssm_svc",
      "target_scope": {
        "tags": ["ssm", "secrets"],
        "bindings": [
          {
            "kind": "peripheral",
            "name": "ssm_svc",
            "cardinality": "many",
            "where": { "service_type": "ssm" }
          }
        ]
      },
      "steps": [
        {
          "title": "Enumerate Parameters",
          "description": "Recursive listing of parameters.",
          "tool": "aws-cli",
          "action": "execute",
          "arguments": ["ssm get-parameters-by-path --path / --recursive"]
        },
        {
          "title": "Decrypt SecureStrings",
          "description": "Attempt decryption of identified secrets.",
          "tool": "aws-cli",
          "action": "execute",
          "arguments": ["ssm get-parameter --name <PARAM> --with-decryption"]
        }
      ]
    },
